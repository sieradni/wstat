<Window x:Class="Wstat.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="wstat — Screen Time Tracker"
        Height="550" Width="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button" x:Key="FilterButton">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="wstat — Screen Time Tracker"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Today" Style="{StaticResource FilterButton}"
                    Command="{Binding FilterTodayCommand}"/>
            <Button Content="Yesterday" Style="{StaticResource FilterButton}"
                    Command="{Binding FilterYesterdayCommand}"/>
            <Button Content="Last 7 Days" Style="{StaticResource FilterButton}"
                    Command="{Binding FilterLast7DaysCommand}"/>
            <Button Content="Last 30 Days" Style="{StaticResource FilterButton}"
                    Command="{Binding FilterLast30DaysCommand}"/>
        </StackPanel>

        <TabControl Grid.Row="2">
            <TabItem Header="Applications">
                <Grid>
                    <DataGrid ItemsSource="{Binding Applications}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Application" Binding="{Binding AppName}" Width="*"/>
                            <DataGridTextColumn Header="Time Spent" Binding="{Binding DisplayTime}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Websites">
                <Grid>
                    <DataGrid ItemsSource="{Binding TopUrls}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="200"/>
                            <DataGridTextColumn Header="Visits" Binding="{Binding VisitCount}" Width="80"/>
                            <DataGridTextColumn Header="Time Spent" Binding="{Binding DisplayTime}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
