<Window x:Class="Wstat.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="wstat Settings" Height="200" Width="380"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <StackPanel Margin="20">
        <TextBlock Text="General" FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>
        <CheckBox Content="Launch wstat when Windows starts"
                  IsChecked="{Binding AutoStartup}"
                  Margin="0,0,0,24"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Padding="20,6" Margin="0,0,8,0"
                    IsDefault="True"
                    Command="{Binding SaveCommand}"/>
            <Button Content="Cancel" Padding="20,6"
                    IsCancel="True"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>
